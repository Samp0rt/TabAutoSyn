# Copy to ".env" in the project root (python-dotenv loads it on import).
#   cp .env.example .env
#
# ---------------------------------------------------------------------------
# OpenRouter — required for TabAutoSyn.generate()
# ---------------------------------------------------------------------------
# API key from https://openrouter.ai/keys — used by Pydantic-AI agents
# (dependency discovery, dependency fixer, optional dataset description).
OPENROUTER_API_KEY=

# OpenRouter model id for all meta-agents in generate() when not overridden in code.
# Example: anthropic/claude-haiku-4.5, google/gemini-2.5-flash
DEFAULT_META_MODEL=anthropic/claude-haiku-4.5

# ---------------------------------------------------------------------------
# Langfuse — optional tracing for generate() and agents
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Cloud: https://cloud.langfuse.com  | self-hosted: your Langfuse host URL
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ---------------------------------------------------------------------------
# Local LLM (Ollama) — no keys required in .env
# ---------------------------------------------------------------------------
# TabAutoSyn._generate_synthetics_llm uses a fixed OpenAI-compatible URL:
#   http://localhost:11434/v1  with api_key="ollama"
# Default model tag in code: gpt-oss:20b  →  run:  ollama pull gpt-oss:20b
# See README “Ollama and gpt-oss”.
